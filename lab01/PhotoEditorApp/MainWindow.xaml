<Window x:Class="PhotoEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:PhotoEditor"
        Title="Prototype Lab" Height="850" Width="1250" Background="#111">
    
    <Window.Resources>
        <local:NegativeConverter x:Key="NegativeConverter"/>
        <local:WarmthToColorConverter x:Key="WarmthToColorConverter"/>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="140"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#1A1A1A" BorderBrush="#333" BorderThickness="0,0,1,0">
                <StackPanel Margin="15">
                    <Button Content="ИМПОРТ ФОТО" Click="AddImage_Click" Height="35" Background="#007ACC" Foreground="White" BorderThickness="0" FontWeight="Bold"/>
                    <TextBlock Text="ПРЕСЕТЫ" Margin="0,30,0,10" Foreground="#666" FontSize="10" FontWeight="Bold"/>
                    <Button Content="Копировать настройки" Click="CopyStyle_Click" Margin="0,5" Height="32" Background="#333" Foreground="#CCC"/>
                    <Button Content="Вставить настройки" Click="PasteStyle_Click" Margin="0,5" Height="32" Background="#333" Foreground="#CCC"/>
                    <TextBlock x:Name="StatusText" Foreground="#007ACC" Margin="0,20" TextWrapping="Wrap" FontSize="11"/>
                </StackPanel>
            </Border>

            <Grid Grid.Column="1" Background="#050505">
                <Viewbox Margin="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Grid x:Name="ActivePhotoContainer" DataContext="{Binding SelectedItem, ElementName=ThumbnailList}">
                        
                        <Grid.Effect>
                            <BlurEffect Radius="{Binding Settings.BlurRadius}"/>
                        </Grid.Effect>

                        <Image Source="{Binding GrayscaleSource}" 
                            Visibility="{Binding Settings.IsBW, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        
                        <Image Source="{Binding ImageSource}" 
                            Visibility="{Binding Settings.IsBW, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter='invert'}"/>
                        
                        <Rectangle Fill="White" Opacity="{Binding Settings.AbsExposure}" IsHitTestVisible="False">
                            <Rectangle.Style>
                                <Style TargetType="Rectangle">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Settings.Exposure, Converter={StaticResource NegativeConverter}, ConverterParameter='invert'}" Value="False">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Rectangle.Style>
                        </Rectangle>
                        
                        <Rectangle Fill="Black" Opacity="{Binding Settings.AbsBrightness}" IsHitTestVisible="False">
                            <Rectangle.Style>
                                <Style TargetType="Rectangle">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Settings.Brightness, Converter={StaticResource NegativeConverter}}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Rectangle.Style>
                        </Rectangle>

                        <Rectangle Fill="{Binding Settings.Warmth, Converter={StaticResource WarmthToColorConverter}}" 
                                Opacity="{Binding Settings.AbsWarmth}" IsHitTestVisible="False"/>
                    </Grid>
                </Viewbox>
            </Grid>

            <Border Grid.Column="2" Background="#1A1A1A" BorderBrush="#333" BorderThickness="1,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20" DataContext="{Binding SelectedItem, ElementName=ThumbnailList}">
                        <TextBlock Text="СВЕТ И ЭФФЕКТЫ" Foreground="#007ACC" FontWeight="Bold" Margin="0,0,0,20"/>
                        
                        <CheckBox Content="Черно-белый фильтр" IsChecked="{Binding Settings.IsBW}" Foreground="#AAA" Margin="0,0,0,20"/>

                        <TextBlock Text="Размытие" Foreground="#AAA" FontSize="11"/>
                        <Slider Minimum="0" Maximum="40" Value="{Binding Settings.BlurRadius}" Margin="0,5,0,20"/>

                        <TextBlock Text="Экспозиция" Foreground="#AAA" FontSize="11"/>
                        <Slider Minimum="0" Maximum="0.6" Value="{Binding Settings.Exposure}" Margin="0,5,0,20"/>

                        <TextBlock Text="Яркость" Foreground="#AAA" FontSize="11"/>
                        <Slider Minimum="-0.7" Maximum="0" Value="{Binding Settings.Brightness}" Margin="0,5,0,20"/>

                        <TextBlock Text="Теплота" Foreground="#AAA" FontSize="11"/>
                        <Slider Minimum="-0.5" Maximum="0.5" Value="{Binding Settings.Warmth}" Margin="0,5,0,20"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Grid.Row="1" Background="#111" BorderBrush="#333" BorderThickness="0,1,0,0">
            <ListBox x:Name="ThumbnailList" Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Auto">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" Margin="5"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="5" Padding="2" BorderBrush="#444" BorderThickness="1" Background="#222">
                            <Image Source="{Binding ImageSource}" Width="120" Height="80" Stretch="UniformToFill"/>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>
    </Grid>
</Window>